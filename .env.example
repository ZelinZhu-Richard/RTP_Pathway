# Required only to enable the /admin area.
# Generate a strong value with: openssl rand -hex 24
ADMIN_PASSWORD=

# Optional: enables Claude-backed extraction, search explanations, and Q&A.
# Leave empty to use the app's deterministic fallbacks.
ANTHROPIC_API_KEY=

# Optional: overrides the default model configured in src/lib/claude/client.ts.
CLAUDE_MODEL=claude-opus-4-8

# Optional: SQLite database path, relative to the repository root.
DATABASE_PATH=data/rtp.db

# Optional: mirror web-form submissions to a private staff Google Sheet.
# Share the spreadsheet with GOOGLE_SERVICE_ACCOUNT_EMAIL before enabling.
# These values are server-only; never rename them with a NEXT_PUBLIC_ prefix.
GOOGLE_SHEETS_SYNC_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_TAB=Submissions
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the JSON credential's private_key with literal \n line breaks.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Optional: uncomment when your network requires an outbound proxy.
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1
