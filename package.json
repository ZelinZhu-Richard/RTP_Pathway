{
  "name": "rtp-pathway",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "npm run test:ts && npm run test:pipeline",
    "test:ts": "tsx --test src/lib/*.test.ts src/lib/claude/*.test.ts",
    "test:pipeline": "python3 -m unittest discover -s pipeline -p 'test_*.py'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "pipeline:seed": "python3 pipeline/clean_csv.py data/seed_opportunities_raw.csv -o data/seed_opportunities_clean.csv --report data/quality_report.md && python3 pipeline/import_db.py data/seed_opportunities_clean.csv --db data/rtp.db",
    "setup": "npm run db:migrate && npm run pipeline:seed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "next": "15.5.20",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^3.9.2",
    "undici": "^8.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
